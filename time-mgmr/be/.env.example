# Optional: override AWS region for local tooling (SST uses your AWS profile by default)
# AWS_REGION=ap-southeast-1

# Used by scripts/seed-user.ts when .sst/outputs.json is unavailable
# TABLE_NAME=time-mgmr-dev-TimeMgmrTableTable-xxxxx

# Frontend origin for CORS — also configured in sst.config.ts
# FRONTEND_URL=http://localhost:3000

# Web Push (VAPID) — do not put real keys in source control.
# Generate and store as SST secrets for each stage:
#   npx web-push generate-vapid-keys
#   npx sst secret set VapidPublicKey '<public>'
#   npx sst secret set VapidPrivateKey '<private>'
